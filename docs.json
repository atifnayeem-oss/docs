{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ringup",
  "description": "Identity and payments for voice agents",
  "colors": {
    "primary": "#2450C8",
    "light": "#6E92EC",
    "dark": "#1B3C9E"
  },
  "fonts": {
    "heading": {
      "family": "Fraunces"
    },
    "body": {
      "family": "Hanken Grotesk"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quickstart",
              "authentication",
              "concepts/how-it-works",
              "concepts/testing"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/identity",
              "concepts/merchant-identity",
              "concepts/checkout-session",
              "concepts/payment-policy",
              "concepts/send-link",
              "concepts/charge",
              "concepts/webhooks"
            ]
          },
          {
            "group": "Voice integrations",
            "pages": [
              {
                "group": "Vapi",
                "pages": [
                  "integrations/vapi/native",
                  "integrations/vapi/call-transfer",
                  "integrations/vapi/testing"
                ]
              },
              "integrations/retell",
              "integrations/elevenlabs",
              "integrations/deepgram",
              "integrations/twilio-conversationrelay",
              "integrations/livekit",
              "integrations/openai-realtime",
              "integrations/pipecat"
            ]
          },
          {
            "group": "Payment providers",
            "pages": [
              "payment-providers/overview",
              "payment-providers/square"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API reference",
            "pages": [
              "api-reference/introduction",
              "api-reference/errors"
            ]
          },
          {
            "group": "Tools",
            "openapi": "api-reference/openapi.json"
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "pages": [
              "changelog"
            ]
          }
        ]
      }
    ]
  },
  "api": {
    "playground": {
      "display": "interactive"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "ringup.dev",
        "href": "https://ringup.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get access",
      "href": "https://ringup.dev/#access"
    }
  },
  "footer": {
    "socials": {
      "website": "https://ringup.dev"
    }
  },
  "redirects": [
    {
      "source": "/integrations/vapi",
      "destination": "/integrations/vapi/native"
    },
    {
      "source": "/concepts/call-transfer",
      "destination": "/concepts/checkout-session"
    },
    {
      "source": "/guides/connect-merchants",
      "destination": "/payment-providers/square"
    },
    {
      "source": "/integrations/retell/call-transfer",
      "destination": "/integrations/retell"
    }
  ]
}